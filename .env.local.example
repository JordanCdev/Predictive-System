# AI chat — LOCAL DEV configuration only.
#
# The app deploys to GitHub Pages (a static host with no backend), so the LIVE
# site uses BYOK: each visitor pastes their own Anthropic key into the chat card,
# and it stays in their browser. There is no server key in production.
#
# This file is only for running the chat through the LOCAL dev proxy so you don't
# have to paste a key into the browser while developing. Copy it to `.env.local`
# (gitignored) and fill in your key, then `npm run dev`.
#
# Safe for GitHub Pages: `.env.local` is gitignored and absent from CI, so the
# deploy workflow builds WITHOUT these values — the published site is always BYOK.

# Your Anthropic API key. Read only by the dev proxy (server side); never bundled.
ANTHROPIC_API_KEY=sk-ant-...

# Point the app at the local dev proxy (the /api/chat middleware in vite.config.ts).
# Do NOT set this for a production build — leave the deployed site on BYOK.
VITE_AI_PROXY_URL=/api/chat

# ── Firebase (optional) — accounts, Google login, cloud profile sync ──────────
# All values are PUBLIC (the web apiKey is an identifier, not a secret; access is
# controlled by Firestore rules + Auth). Get them from the Firebase console →
# Project settings → your web app, or `firebase apps:sdkconfig`. With these set,
# the app enables Google sign-in + cloud profile sync; without them it runs fully
# client-side on localStorage. See docs/FIREBASE_SETUP.md.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# For the server-side AI: after deploying the Cloud Function, set VITE_AI_PROXY_URL
# to its URL, e.g. https://us-central1-your-project.cloudfunctions.net/chat
# (the function verifies the signed-in user's Firebase ID token).

# ── Billing (optional) — Free/Pro subscriptions ──────────────────────────────
# The deployed `billing` Cloud Function (Stripe Checkout + customer portal).
# Unset → the app runs Free-only and hides every upgrade affordance rather than
# offering a CTA that goes nowhere. See docs/BILLING_SETUP.md.
VITE_BILLING_URL=

# DEV ONLY. "pro" unlocks the paid surface locally so gated screens can be worked
# on without a real subscription (npm run dev:pro sets this for you). Read behind
# import.meta.env.DEV, so Vite strips it from any production build.
VITE_DEV_FORCE_PLAN=

# Stripe keys live SERVER-side only, as Cloud Function secrets — never here, and
# never in a VITE_ variable (those are bundled into the public JS):
#   firebase functions:secrets:set STRIPE_SECRET_KEY
#   firebase functions:secrets:set STRIPE_WEBHOOK_SECRET
# plus params STRIPE_PRICE_PRO_MONTH / STRIPE_PRICE_PRO_YEAR.
