# AI chat — local dev configuration.
# Copy this file to `.env.local` (which is gitignored) and fill in your key.
# With both set, `npm run dev` serves the chat through the local proxy in
# vite.config.ts, so the key stays on the server side and never touches the
# browser. Leave the file absent to use BYOK (paste your key into the app UI).

# Your Anthropic API key. Server-side only — never exposed to the client bundle.
ANTHROPIC_API_KEY=sk-ant-...

# Point the app at the local dev proxy (the /api/chat middleware).
VITE_AI_PROXY_URL=/api/chat
