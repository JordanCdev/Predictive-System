rules_version = '2';

// Every document lives under users/{uid}/… and is readable/writable only by that
// signed-in user. Birth data never leaves the owner's account.
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ONE rule covers the whole user tree, because Firestore rules are OR'd: a
    // separate `match /users/{uid}/{document=**}` granting write would re-open
    // the billing documents no matter what a narrower rule below it said. So the
    // billing exclusion lives inside the same condition as the grant.
    //
    // Billing is SERVER-OWNED — the owner reads their entitlement, plan and AI
    // meter, but only the Stripe webhook and the chat function (Admin SDK, which
    // bypasses these rules entirely) may write them. Otherwise a user could write
    // themselves a "pro" record, or zero out their own usage counter.
    match /users/{uid}/{coll}/{document=**} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid) && coll != 'billing';
    }

    // Deny everything else, including the server-only stripeCustomers/{id} → uid
    // mirror the webhook uses to map an event back to an account.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
